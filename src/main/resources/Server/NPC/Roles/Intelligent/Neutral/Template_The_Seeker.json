{
  "$Comment": "Debug: DisplayState",
  "Debug": "DisplayState",
  "Type": "Abstract",
  "Appearance": "BO_The_Seeker",
  "Parameters": {
    "DropList": {
      "Value": "Empty",
      "Description": "Drop Items"
    },
    "Appearance": {
      "Value": "Seeker",
      "Description": "Model to be used"
    },
    "MaxHealth": {
      "Value": 180,
      "Description": "Max health for the NPC"
    },
    "EatItem": {
      "Value": "Ingredient_Bar_Iron",
      "Description": "The item this NPC will find when it rummages for food"
    },
    "ViewRange": {
      "Value": 16,
      "Description": "View range in blocks"
    },
    "ViewSector": {
      "Value": 360,
      "Description": "View sector in degrees"
    },
    "HearingRange": {
      "Value": 32,
      "Description": "Hearing range in blocks"
    },
    "AlertedRange": {
      "Value": 40,
      "Description": "Range within which an alerted Seeker pursues its target (the marked workbench or nearest player)"
    },
    "LockedTargetRange": {
      "Value": 256,
      "Description": "Range within which a force-marked wave target can pull the Seeker into pursuit"
    },
    "AttackDistance": {
      "Value": 2.5,
      "Description": "The distance at which an NPC will execute attacks"
    },
    "FleeRange": {
      "Value": 12,
      "Description": "Distance the Seeker tries to keep from players while scared"
    },
    "ScaredDuration": {
      "Value": [
        1,
        3
      ],
      "Description": "How long the Seeker remains scared after it loses sight of the light source"
    },
    "AttackSequence": {
      "Value": "Component_Instruction_Attack_Sequence_Seeker",
      "Description": "Attack sequence used while the Seeker is angry"
    },
    "FlashlightItems": {
      "Value": [
        "BO_Flashlight"
      ],
      "TypeHint": "String",
      "Description": "Legacy item-list parameter for role-side ItemInHand filters. The active flashlight scare logic is handled by FlashlightScareService, because SetState swaps the held stack to generated item ids such as '*BO_Flashlight_State_On' and only the On state carries Light."
    },
    "NameTranslationKey": {
      "Value": "Template_The_Seeker",
      "Description": "Translation key for NPC name display"
    }
  },
  "DropList": {
    "Compute": "DropList"
  },
  "MaxHealth": {
    "Compute": "MaxHealth"
  },
  "DisableDamageGroups": [
    "Self"
  ],
  "StartState": "Peaceful",
  "DefaultPlayerAttitude": "Neutral",
  "DefaultNPCAttitude": "Ignore",
  "KnockbackScale": 0.5,
  "MotionControllerList": [
    {
      "Type": "Walk",
      "MaxWalkSpeed": 3,
      "Gravity": 10,
      "MaxFallSpeed": 8,
      "Acceleration": 10
    }
  ],
  "InteractionVars": {
    "Melee_Start": {
      "Interactions": [
        {
          "$Comment": "Full Seeker melee swing including animation, selector, and damage hook",
          "Parent": "BO_Seeker_Swing"
        }
      ]
    },
    "Melee_Damage": {
      "Interactions": [
        {
          "Parent": "BO_Seeker_Damage"
        }
      ]
    }
  },
  "Instructions": [
    {
      "Instructions": [
        {
          "Sensor": {
            "Type": "State",
            "State": "Peaceful"
          },
          "Instructions": [
            {
              "$Comment": "A lit flashlight nearby scares the NPC only during wave night mode. FlashlightNear and NightMode are set each tick by the plugin's FlashlightScareService.",
              "Sensor": {
                "Type": "And",
                "Sensors": [
                  {
                    "Type": "Flag",
                    "Name": "FlashlightNear",
                    "Set": true
                  },
                  {
                    "Type": "Flag",
                    "Name": "NightMode",
                    "Set": true
                  }
                ]
              },
              "Actions": [
                {
                  "Type": "State",
                  "State": "Scared"
                }
              ]
            },
            {
              "$Comment": "Wave night mode makes the NPC angry regardless of local block light. The wave code sets NightMode from the world blackout state instead of relying on JSON Light sensors.",
              "Sensor": {
                "Type": "Flag",
                "Name": "NightMode",
                "Set": true
              },
              "Actions": [
                {
                  "Type": "State",
                  "State": "Angry"
                }
              ]
            },
            {
              "Reference": "Component_Instruction_Clear_Status_Animation"
            },
            {
              "Continue": true,
              "Sensor": {
                "Type": "Any"
              },
              "Actions": [
                {
                  "Type": "SetStat",
                  "Stat": "Health",
                  "Value": {
                    "Compute": "MaxHealth"
                  }
                }
              ]
            },
            {
              "Continue": true,
              "Sensor": {
                "Type": "Any",
                "Once": true
              },
              "Actions": [
                {
                  "Type": "Inventory",
                  "Operation": "EquipHotbar",
                  "Slot": 0,
                  "UseTarget": false
                }
              ]
            },
            {
              "Sensor": {
                "Type": "Any"
              },
              "BodyMotion": {
                "Type": "Wander",
                "RelativeSpeed": 0.35,
                "MinWalkTime": 0.5
              }
            }
          ]
        },
        {
          "Sensor": {
            "Type": "State",
            "State": "Scared"
          },
          "Instructions": [
            {
              "$Comment": "Lights-on/rest mode immediately makes persistent SCP-3008 style variants passive again.",
              "Sensor": {
                "Type": "Flag",
                "Name": "NightMode",
                "Set": false
              },
              "Actions": [
                {
                  "Type": "ReleaseTarget"
                },
                {
                  "Type": "State",
                  "State": "Peaceful"
                }
              ]
            },
            {
              "Continue": true,
              "Sensor": {
                "Type": "Any",
                "Once": true
              },
              "Actions": [
                {
                  "Type": "PlayAnimation",
                  "Slot": "Status",
                  "Animation": "Alerted"
                },
                {
                  "Type": "SpawnParticles",
                  "Offset": [
                    0,
                    0.8,
                    0
                  ],
                  "ParticleSystem": "Alerted"
                }
              ]
            },
            {
              "$Comment": "Stop being scared once no lit flashlight is near (FlashlightNear cleared). Wait out ScaredDuration first so it doesn't flip back the instant the light leaves range. The player-in-range Flee below drives the actual retreat while scared.",
              "Sensor": {
                "Type": "Flag",
                "Name": "FlashlightNear",
                "Set": false
              },
              "ActionsAtomic": true,
              "Actions": [
                {
                  "Type": "Timeout",
                  "Delay": {
                    "Compute": "ScaredDuration"
                  }
                },
                {
                  "Type": "ReleaseTarget"
                },
                {
                  "Type": "State",
                  "State": "Peaceful"
                }
              ]
            },
            {
              "Sensor": {
                "Type": "Player",
                "Range": {
                  "Compute": "ViewRange"
                }
              },
              "BodyMotion": {
                "Type": "Flee",
                "SlowDownDistance": {
                  "Compute": "FleeRange"
                },
                "StopDistance": {
                  "Compute": "FleeRange + 2"
                },
                "RelativeSpeed": 1
              },
              "HeadMotion": {
                "Type": "Watch"
              }
            },
            {
              "Sensor": {
                "Type": "Any"
              },
              "BodyMotion": {
                "Type": "Wander",
                "RelativeSpeed": 0.8,
                "MinWalkTime": 0.5
              }
            }
          ]
        },
        {
          "Sensor": {
            "Type": "State",
            "State": "Angry"
          },
          "Instructions": [
            {
              "$Comment": "Lights-on/rest mode calms persistent SCP-3008 style variants back to Peaceful. Normal Seekers have NightMode forced on by Java while alive.",
              "Sensor": {
                "Type": "Flag",
                "Name": "NightMode",
                "Set": false
              },
              "Actions": [
                {
                  "Type": "ReleaseTarget"
                },
                {
                  "Type": "State",
                  "State": "Peaceful"
                }
              ]
            },
            {
              "$Comment": "A lit flashlight nearby (FlashlightNear flag) scares the NPC while night mode is active: drop the target and flee.",
              "Sensor": {
                "Type": "And",
                "Sensors": [
                  {
                    "Type": "Flag",
                    "Name": "FlashlightNear",
                    "Set": true
                  },
                  {
                    "Type": "Flag",
                    "Name": "NightMode",
                    "Set": true
                  }
                ]
              },
              "Actions": [
                {
                  "Type": "ReleaseTarget"
                },
                {
                  "Type": "State",
                  "State": "Scared"
                }
              ]
            },
            {
              "Continue": true,
              "Sensor": {
                "Type": "Any",
                "Once": true
              },
              "Actions": [
                {
                  "Type": "SpawnParticles",
                  "Offset": [
                    0,
                    0.8,
                    0
                  ],
                  "ParticleSystem": "Alerted"
                }
              ]
            },
            {
              "$Comment": "Pursue a force-marked objective (e.g. the workbench) even though its attitude is Ignore and it can't be sensed by sight/sound.",
              "Sensor": {
                "Type": "Target",
                "TargetSlot": "LockedTarget",
                "Range": {
                  "Compute": "LockedTargetRange"
                }
              },
              "Actions": [
                {
                  "Type": "OverrideAttitude",
                  "Attitude": "Hostile",
                  "Duration": 120
                },
                {
                  "Type": "State",
                  "State": "Attack"
                }
              ]
            },
            {
              "Sensor": {
                "Type": "Or",
                "Sensors": [
                  {
                    "Reference": "Component_Sensor_Sight_By_Attitude",
                    "Modify": {
                      "ViewRange": {
                        "Compute": "ViewRange"
                      },
                      "ViewSector": {
                        "Compute": "ViewSector"
                      },
                      "Attitudes": [
                        "Hostile",
                        "Neutral"
                      ]
                    }
                  },
                  {
                    "Reference": "Component_Sensor_Sound_By_Attitude",
                    "Modify": {
                      "HearingRange": {
                        "Compute": "HearingRange"
                      },
                      "Attitudes": [
                        "Hostile",
                        "Neutral"
                      ]
                    }
                  }
                ]
              },
              "Actions": [
                {
                  "Type": "OverrideAttitude",
                  "Attitude": "Hostile",
                  "Duration": 120
                },
                {
                  "Type": "State",
                  "State": "Attack"
                }
              ]
            },
            {
              "Sensor": {
                "Type": "Any"
              },
              "BodyMotion": {
                "Type": "Wander",
                "RelativeSpeed": 0.65,
                "MinWalkTime": 0.5
              }
            }
          ]
        },
        {
          "Sensor": {
            "Type": "State",
            "State": "Attack"
          },
          "Instructions": [
            {
              "$Comment": "Lights-on/rest mode calms persistent SCP-3008 style variants back to Peaceful. Normal Seekers have NightMode forced on by Java while alive.",
              "Sensor": {
                "Type": "Flag",
                "Name": "NightMode",
                "Set": false
              },
              "Actions": [
                {
                  "Type": "ReleaseTarget"
                },
                {
                  "Type": "State",
                  "State": "Peaceful"
                }
              ]
            },
            {
              "$Comment": "A lit flashlight nearby (FlashlightNear flag) scares the NPC while night mode is active: drop the target and flee.",
              "Sensor": {
                "Type": "And",
                "Sensors": [
                  {
                    "Type": "Flag",
                    "Name": "FlashlightNear",
                    "Set": true
                  },
                  {
                    "Type": "Flag",
                    "Name": "NightMode",
                    "Set": true
                  }
                ]
              },
              "Actions": [
                {
                  "Type": "ReleaseTarget"
                },
                {
                  "Type": "State",
                  "State": "Scared"
                }
              ]
            },
            {
              "Reference": "Component_Instruction_Clear_Status_Animation"
            },
            {
              "$Comment": "Commit to the swing once the target is in reach. Blocking with a pre/post delay (like the wolf) so the attack animation and damage actually resolve instead of being cut short by the seek motion below.",
              "Continue": true,
              "Sensor": {
                "Type": "Target",
                "TargetSlot": "LockedTarget",
                "Range": {
                  "Compute": "AttackDistance + 1"
                }
              },
              "ActionsBlocking": true,
              "Actions": [
                {
                  "Type": "Timeout",
                  "Delay": [
                    0.3,
                    0.3
                  ]
                },
                {
                  "Type": "Attack",
                  "Attack": "Root_NPC_Attack_Melee",
                  "AttackPauseRange": [
                    0.6,
                    1
                  ]
                },
                {
                  "Type": "Timeout",
                  "Delay": [
                    0.4,
                    0.4
                  ]
                }
              ],
              "HeadMotion": {
                "Type": "Aim",
                "RelativeTurnSpeed": 1.5
              }
            },
            {
              "Sensor": {
                "Type": "Target",
                "TargetSlot": "LockedTarget",
                "Range": {
                  "Compute": "LockedTargetRange"
                }
              },
              "BodyMotion": {
                "Type": "Seek",
                "SlowDownDistance": {
                  "Compute": "AttackDistance + 2"
                },
                "StopDistance": {
                  "Compute": "AttackDistance"
                },
                "RelativeSpeed": 1
              }
            },
            {
              "ActionsAtomic": true,
              "Actions": [
                {
                  "Type": "Timeout",
                  "Delay": [
                    3,
                    4
                  ]
                },
                {
                  "Type": "State",
                  "State": "Angry"
                }
              ]
            }
          ]
        }
      ]
    }
  ],
  "NameTranslationKey": {
    "Compute": "NameTranslationKey"
  }
}
